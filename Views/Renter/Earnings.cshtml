@model RenterFinanceViewModel

<div class="container mt-4">
    <h2 class="mb-4">@Localizer["MyEarnings"]</h2>

    <div class="card bg-primary text-white shadow-sm mb-5">
        <div class="card-body text-center p-5">
            <h4 class="text-uppercase small fw-bold">Total Ganho (Reservas Confirmadas)</h4>
            <h1 class="display-3 fw-bold">@Model.TotalEarnings.ToString("C2")</h1>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold">Histórico de Reservas</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Alojamento</th>
                            <th>Hóspede</th>
                            <th>Check-In / Out</th>
                            <th>Valor</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model.Bookings)
                        {
                            <tr>
                                <td><strong>@booking.HousingName</strong></td>
                                <td>@booking.GuestName</td>
                                <td class="small">
                                    @booking.CheckIn.ToShortDateString() a @booking.CheckOut.ToShortDateString()
                                </td>
                                <td class="fw-bold text-success">@booking.Amount.ToString("C2")</td>
                                <td>
                                    <span class="badge @(booking.Status == "CONFIRMED" ? "bg-success" : "bg-warning text-dark")">
                                        @booking.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>