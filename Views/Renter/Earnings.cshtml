@model RenterFinanceViewModel

<div class="container mt-4">
    <h2 class="mb-4">@Localizer["MyEarnings"]</h2>

    <div class="card bg-primary text-white shadow-sm mb-5">
        <div class="card-body text-center p-5">
            <h4 class="text-uppercase small fw-bold">Total Ganho Líquido (Reservas Confirmadas)</h4>
            <h1 class="display-3 fw-bold">@Model.TotalEarnings.ToString("C2")</h1>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold">Histórico de Reservas</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Alojamento</th>
                            <th>Hóspede</th>
                            <th>Check-In / Out</th>
                            <th>Valor Bruto</th>
                            <th>Comissão (Plataforma)</th>
                            <th>O meu Ganho (Líquido)</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Bookings != null && Model.Bookings.Any())
                        {
                            @foreach (var item in Model.Bookings)
                            {
                                var valorLiquido = item.Amount - item.CommissionValue;

                                <tr>
                                    <td class="fw-bold">@item.HousingName</td>
                                    <td>@item.GuestName</td>
                                    <td>
                                        <small class="text-muted">
                                            @item.CheckIn.ToString("dd/MM/yyyy") a @item.CheckOut.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>
                                    <td>@item.Amount.ToString("C2")</td>
                                    <td class="text-danger">
                                        - @item.CommissionValue.ToString("C2")
                                    </td>
                                    <td class="fw-bold text-success" style="font-size: 1.1rem;">
                                        @valorLiquido.ToString("C2")
                                    </td>
                                    <td>
                                        <span class="badge @(item.Status.ToUpper() == "CONFIRMED" ? "bg-success" : "bg-warning text-dark")">
                                            @item.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-info-circle me-2"></i>Nenhuma reserva encontrada para a sua empresa.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #6c757d;
        border-top: none;
    }

    .card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
    }

    .bg-primary {
        background: linear-gradient(135deg, #0d6efd 0%, #004dbd 100%) !important;
    }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s ease;
    }

    .badge {
        padding: 0.5em 0.8em;
        border-radius: 6px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.7rem;
    }
</style>