@model Booking.web.Models.LoginModel

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">

        @* ssessao ativa *@
        @if (ViewBag.ShowForceLoginPrompt == true)
        {
            <div class="alert alert-warning mt-5 shadow-sm border-warning">
                <h5 class="text-center">@Localizer["ActiveSessionDetected"]</h5>
                <p class="small text-center">Já tem uma sessão iniciada noutro dispositivo. Deseja encerrá-la e entrar neste?</p>
                <form asp-action="Login" method="post">
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Passwordhash" />
                    <input type="hidden" name="force" value="true" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger">Sim, encerrar outra sessão</button>
                        <a href="/Account/Login" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        }

        @* condição se estiver ativo *@
        <div class="card mt-5 @(ViewBag.ShowForceLoginPrompt == true ? "d-none" : "")">
            <div class="card-body p-4">

                <h3 class="text-center mb-4">@Localizer["SignIn"]</h3>

                <form asp-action="Login" method="post" novalidate>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">@Localizer["EmailAddress"]</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Passwordhash" class="form-label">@Localizer["Password"]</label>
                        <input asp-for="Passwordhash"
                               type="password"
                               class="form-control" />
                        <span asp-validation-for="Passwordhash" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">
                            @Localizer["SignIn"]
                        </button>
                    </div>

                </form>

                <hr class="my-4" />

                <div class="d-grid">
                    <a href="/Account/Register" class="btn btn-outline-primary btn-lg">
                        @Localizer["CreateAccount"]
                    </a>
                </div>

            </div>
        </div>

    </div>
</div>